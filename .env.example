# 노션 API 설정 — 로컬 빌드 시 .env 파일로 복사해서 사용
# (Netlify에서는 사이트 환경 변수에 동일한 키로 등록)
#
# 1) 노션에서 Integration 만들기 → Internal Integration Secret 발급
#    https://www.notion.so/profile/integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2) 각 데이터베이스 ID — 노션 DB URL의 32자리 영숫자
#    예) https://www.notion.so/workspace/abc123...?v=xyz → DB_ID = abc123...
STORIES_DB_ID=
NEWS_DB_ID=
FILMS_DB_ID=
READERS_DB_ID=

# 미설정 시 해당 콘텐츠 타입은 시드 JSON 그대로 유지됩니다.
