{
  "name": "5ftmag-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "5ft.mag | 필름 매거진 웹사이트",
  "scripts": {
    "validate": "node scripts/validate-assets.mjs",
    "qa": "npm run validate && node scripts/qa-smoke.mjs",
    "qa:visual": "node scripts/qa-visual.mjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "optimize-images": "python3 scripts/optimize-images.py",
    "prebuild": "node scripts/validate-assets.mjs",
    "build": "node scripts/build-from-notion.mjs && node scripts/build-films.mjs && node scripts/build-authors.mjs && node scripts/build-rss.mjs && node scripts/build-sitemap.mjs",
    "build:dry": "DRY_RUN=1 node scripts/build-from-notion.mjs",
    "build:rss": "node scripts/build-rss.mjs",
    "build:authors": "node scripts/build-authors.mjs",
    "build:sitemap": "node scripts/build-sitemap.mjs",
    "build:films": "node scripts/build-films.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
